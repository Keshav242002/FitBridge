# 100ms credentials — get from https://dashboard.100ms.live/
HMS_APP_ACCESS_KEY=your_100ms_app_access_key_here
HMS_APP_SECRET=your_100ms_app_secret_here
HMS_MANAGEMENT_TOKEN=your_100ms_management_token_here

# Template ID from 100ms dashboard (enables dynamic room creation per call request)
# Get from https://dashboard.100ms.live/ → Templates → copy the template ID
HMS_TEMPLATE_ID=your_100ms_template_id_here

# Pre-created room ID from 100ms dashboard (used as fallback when dynamic room creation fails)
HMS_ROOM_ID=your_100ms_room_id_here

# Fallback: a token copied directly from 100ms dashboard "Join with SDK"
# Used only if HMS_APP_ACCESS_KEY/SECRET are blank. Tokens expire in 2 hours.
HMS_FALLBACK_TOKEN=

# Server
PORT=8787
DATA_FILE=./data.json
