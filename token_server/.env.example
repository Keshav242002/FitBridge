# 100ms credentials — get from https://dashboard.100ms.live/
HMS_APP_ACCESS_KEY=
HMS_APP_SECRET=

# Pre-created room ID from 100ms dashboard (used for all calls in v1)
HMS_ROOM_ID=

# Fallback: a token copied directly from 100ms dashboard "Join with SDK"
# Used only if HMS_APP_ACCESS_KEY/SECRET are blank. Tokens expire in 2 hours.
HMS_FALLBACK_TOKEN=

# Server
PORT=8787
DATA_FILE=./data.json
