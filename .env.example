# Root-level .env.example — mirrors token_server/.env.example
# Copy to token_server/.env and fill in your 100ms credentials before running npm start.

HMS_APP_ACCESS_KEY=your_100ms_app_access_key_here
HMS_APP_SECRET=your_100ms_app_secret_here
HMS_ROOM_ID=your_100ms_room_id_here
HMS_FALLBACK_TOKEN=
PORT=8787
HMS_MANAGEMENT_TOKEN=your_100ms_management_token_here
HMS_TEMPLATE_ID=your_100ms_template_id_here